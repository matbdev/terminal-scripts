#!/usr/bin/env bash
#
# DESCRIPTION:
# Quick helper to stage, commit, and push changes to the current Git repository
# in a single command. Includes an optional "--cicd" flag to automatically open
# the remote pipeline page in the browser.
#

# ==========================================
# Functions to color output
# ==========================================
red()    { echo -e "\e[31m$1\e[0m"; }
green()  { echo -e "\e[32m$1\e[0m"; }
yellow() { echo -e "\e[33m$1\e[0m"; }
blue()   { echo -e "\e[34m$1\e[0m"; }

# Exit on critical error
set -e

# Constants
COMMIT_MSG=""
OPEN_CICD=false

# Parses everything passed after the command
for arg in "$@"; do
    if [ "$arg" == "--cicd" ]; then
        OPEN_CICD=true
    else
        COMMIT_MSG="$arg"
    fi
done

# Prevents running if there's no message
if [ -z "$COMMIT_MSG" ]; then
    red "Error: You need to inform the commit message."
    blue "Usage: save_changes \"your message here\" [--cicd]"
    exit 1
fi

# Git
git add .
git commit -m "$COMMIT_MSG"
git push

# CI/CD
if [ "$OPEN_CICD" = true ]; then
    REMOTE_URL=$(git config --get remote.origin.url)
    
    # Converts Git URL to a Browser URL
    if [[ "$REMOTE_URL" == git@* ]]; then
        # git@gitlab.company.com:group/repo.git -> https://gitlab.company.com/group/repo
        WEB_URL=$(echo "$REMOTE_URL" | sed -e 's/^git@//' -e 's/:/\//' -e 's/\.git$//')
        WEB_URL="https://$WEB_URL"
    elif [[ "$REMOTE_URL" == https://* ]]; then
        # https://gitlab.company.com/group/repo.git -> https://gitlab.company.com/group/repo
        WEB_URL=$(echo "$REMOTE_URL" | sed -e 's/\.git$//')
    else
        red "Unrecognized Git URL format to open in browser."
        exit 0
    fi

    # Builds the GitLab pipelines page URL
    PIPELINE_URL="${WEB_URL}/-/pipelines"

    # The WSL/Windows trick we perfected earlier!
    cmd.exe /c start "" "$PIPELINE_URL" > /dev/null 2>&1
fi

green "Process finished!"