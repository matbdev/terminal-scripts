#!/usr/bin/env bash
#
# DESCRIPTION:
# Opens the current Git repository directly in Databricks Workspace.
# It requires initial configuration (Host, Workspace ID, Email) which is saved for future uses.
# The repository must be cloned in the path defined in the configuration on databricks.
#

# ==========================================
# Functions
# ==========================================
red()    { echo -e "\e[31m$1\e[0m"; }
green()  { echo -e "\e[32m$1\e[0m"; }
yellow() { echo -e "\e[33m$1\e[0m"; }
blue()   { echo -e "\e[34m$1\e[0m"; }

# Exit script on error
set -e

# Checks if inside a Git repository
if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    red "Error: You are not inside a Git repository."
    exit 1
fi

# Gets the repo folder name
REPO_ROOT=$(git rev-parse --show-toplevel)
REPO_NAME=$(basename "$REPO_ROOT")

# ==========================================
# Config
# ==========================================
CONFIG_FILE="$HOME/.config/dbopen.conf"

if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
else
    blue "First access detected! Configuring dbopen."
    
    # Read directly into final variables to avoid errors when saving
    read -p "Type your user (full email): " DBX_USER
    read -p "Type the Databricks Workspace ID: " WORKSPACE_ID
    read -p "Type the root path to git folders: " GIT_ROOT_PATH
    read -p "Type the DBX HOST (ex: https://adb-1234.net): " DBX_HOST
    
    # Ensures the .config folder exists and saves the answers in KEY="VALUE" format
    mkdir -p "$HOME/.config"
    echo "DBX_USER=\"$DBX_USER\"" > "$CONFIG_FILE"
    echo "WORKSPACE_ID=\"$WORKSPACE_ID\"" >> "$CONFIG_FILE"
    echo "GIT_ROOT_PATH=\"$GIT_ROOT_PATH\"" >> "$CONFIG_FILE"
    echo "DBX_HOST=\"$DBX_HOST\"" >> "$CONFIG_FILE"
    
    green "Settings successfully saved in $CONFIG_FILE!"
fi

# Builds the final URL using all configured variables
TARGET_URL="${DBX_HOST}/?o=${WORKSPACE_ID}#workspace/Workspace/Users/${DBX_USER}/${GIT_ROOT_PATH}/${REPO_NAME}"

blue "Opening $REPO_NAME in Databricks..."
echo "URL: $TARGET_URL"

# Calls Windows to open the browser
cmd.exe /c start "" "$TARGET_URL" > /dev/null 2>&1