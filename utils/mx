#!/bin/bash
#
# DESCRIPTION:
# Opens the unique .mpr (Mendix Project) file found in the CURRENT directory.
# Exits with an error if zero or more than one .mpr file is found.
# Uses explorer.exe to open the app on Windows from WSL.
#

set -o errexit
set -o nounset
set -o pipefail

# Finds .mpr (Mendix) files only in the current directory
readarray -t mpr_files < <(find . -maxdepth 1 -type f -name "*.mpr")

# Gets the count of .mpr files found.
file_count="${#mpr_files[@]}"

# Handles cases based on file count.
if [ "${file_count}" -eq 0 ]; then
    echo "Error: No .mpr file found in the current directory." >&2
    exit 1
fi

if [ "${file_count}" -gt 1 ]; then
    echo "Error: Multiple .mpr files found. Expected exactly one." >&2
    printf "Found files:\n" >&2
    printf " - %s\n" "${mpr_files[@]}" >&2
    exit 1
fi

# Exactly one file was found.
target_file="${mpr_files[0]}"

echo "Opening '${target_file}' in Mendix Studio Pro..."

# Converts WSL path to a Windows path and opens with default program.
explorer.exe "$(wslpath -w "${target_file}")" &
